rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow unauthenticated users to upload photos to feedback directory
    match /feedback/{imageId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}