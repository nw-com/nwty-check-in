rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Special rule for Leaves collection to allow unauthenticated approval with valid token
    match /artifacts/{appId}/public/data/leaves/{document=**} {
      allow update: if request.resource.data.verificationToken == resource.data.shareToken;
      allow read, write: if request.auth != null;
    }
    
    // Special rule for Signatures collection to allow unauthenticated approval with valid token
    match /artifacts/{appId}/public/data/signatures/{document=**} {
      allow update: if request.resource.data.verificationToken == resource.data.shareToken;
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users to read and write under the app's public data path
    match /artifacts/{appId}/public/data/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Special rule for Users collection to allow phone number lookup before login
    // Note: This allows public read access to user data. Ensure sensitive data is not stored here.
    match /artifacts/{appId}/public/data/users/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow public read of community list for registration lookup (community code -> name)
    match /artifacts/{appId}/public/data/communities/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow unauthenticated users to submit registrations into a pending collection
    match /artifacts/{appId}/public/data/pending_registrations/{document=**} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Allow unauthenticated users to submit feedbacks, and authenticated users to read/update/delete
    match /feedbacks/{document=**} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
